# Copy this file to .env and fill in real values.
#   cp .env.example .env
# .env is gitignored and must never be committed.

# ---- Database ----
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/future
SPRING_DATASOURCE_USERNAME=future
SPRING_DATASOURCE_PASSWORD=change-me
# Leave blank to let Spring auto-detect the driver for your DB.
SPRING_DATASOURCE_DRIVER_CLASS_NAME=
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ---- Spring ----
SPRING_PROFILES_ACTIVE=prod

# ---- Auth ----
# Generate a long random base64 string, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-base64-secret

# ---- Storage: AWS S3 (used when STORAGE_PROVIDER=S3) ----
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=

# ---- Storage: FTP (used when STORAGE_PROVIDER=FTP) ----
FTP_HOST=host.docker.internal
FTP_PORT=21
FTP_USERNAME=your_ftp_user
FTP_PASSWORD=change-me

# Which storage backend the API uses: FTP or S3
STORAGE_PROVIDER=FTP

# ---- Ports / networking ----
# Port the API listens on internally (also published on the host as API_PORT:API_PORT).
API_PORT=8085
# Upstream the admin container reverse-proxies /api to (compose `api` service : internal port).
# No trailing slash / no path — proxy_pass preserves the /api prefix.
API_UPSTREAM=http://api:8085
# Host port mapped to the admin container (nginx on port 80).
ADMIN_APP_PORT=3000
